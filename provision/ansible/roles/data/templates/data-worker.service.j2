[Unit]
Description=Busibox Data Worker
After=network.target redis-server.service
Wants=redis-server.service
Requires=redis-server.service

[Service]
Type=simple
User=root
WorkingDirectory=/srv/data
EnvironmentFile=/srv/data/.env
ExecStart=/srv/data/venv/bin/python /srv/data/src/worker.py
Restart=always
RestartSec=10

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=data-worker

# Resource limits
LimitNOFILE=65536
MemoryMax=8G

[Install]
WantedBy=multi-user.target

