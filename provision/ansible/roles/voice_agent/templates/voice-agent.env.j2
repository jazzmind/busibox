# Voice Agent Service Configuration
# Generated by Ansible - Do not edit manually

# Service
VOICE_HOST=0.0.0.0
VOICE_PORT={{ voice_agent_port }}
VOICE_DEBUG=false

# PostgreSQL
VOICE_POSTGRES_HOST={{ postgres_host }}
VOICE_POSTGRES_PORT={{ postgres_port }}
VOICE_POSTGRES_DB={{ postgres_db }}
VOICE_POSTGRES_USER={{ postgres_user }}
VOICE_POSTGRES_PASSWORD={{ postgres_password }}

# Test mode
VOICE_TEST_MODE_ENABLED={{ test_mode_enabled | lower }}
VOICE_TEST_DB_NAME={{ test_db_name }}
VOICE_TEST_DB_USER={{ test_db_user }}
VOICE_TEST_DB_PASSWORD={{ test_db_password }}

# FreeSWITCH
VOICE_FREESWITCH_HOST=127.0.0.1
VOICE_FREESWITCH_PORT={{ freeswitch_esl_port }}
VOICE_FREESWITCH_PASSWORD={{ freeswitch_esl_password }}

# SIP Trunk
VOICE_SIP_TRUNK_HOST={{ sip_trunk_host }}
VOICE_SIP_TRUNK_USERNAME={{ sip_trunk_username }}
VOICE_SIP_TRUNK_PASSWORD={{ sip_trunk_password }}
VOICE_SIP_TRUNK_CALLER_ID={{ sip_trunk_caller_id }}

# Whisper STT
VOICE_WHISPER_MODEL={{ whisper_model }}
VOICE_WHISPER_DEVICE={{ whisper_device }}
VOICE_WHISPER_COMPUTE_TYPE={{ whisper_compute_type }}

# LiteLLM
VOICE_LITELLM_BASE_URL={{ litellm_base_url }}
VOICE_LITELLM_API_KEY={{ litellm_api_key }}

# AuthZ
VOICE_AUTHZ_URL={{ authz_url }}

# Ingest API
VOICE_INGEST_API_URL={{ ingest_api_url }}

# Call settings
VOICE_MAX_PARALLEL_CALLS={{ max_parallel_calls }}
VOICE_BACKUP_CALL_DELAY_MINUTES={{ backup_call_delay_minutes }}
VOICE_MAX_CALL_DURATION_MINUTES={{ max_call_duration_minutes }}
