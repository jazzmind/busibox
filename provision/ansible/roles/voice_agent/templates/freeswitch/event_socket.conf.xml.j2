<?xml version="1.0" encoding="utf-8"?>
<!-- Event Socket Configuration - Generated by Ansible -->
<configuration name="event_socket.conf" description="Event Socket Configuration">
  <settings>
    <param name="nat-map" value="false"/>
    <param name="listen-ip" value="127.0.0.1"/>
    <param name="listen-port" value="{{ freeswitch_esl_port }}"/>
    <param name="password" value="{{ freeswitch_esl_password }}"/>
    <!-- Allow connections from localhost only for security -->
    <param name="apply-inbound-acl" value="loopback.auto"/>
  </settings>
</configuration>
