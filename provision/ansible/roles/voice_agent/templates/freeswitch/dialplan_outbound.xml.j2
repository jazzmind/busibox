<?xml version="1.0" encoding="utf-8"?>
<!-- Outbound Dialplan - Generated by Ansible -->
<include>
  <context name="public">
    <!-- Outbound calls via Telnyx -->
    <extension name="outbound_telnyx">
      <condition field="destination_number" expression="^(\+?1?\d{10,15})$">
        <action application="set" data="effective_caller_id_number={{ sip_trunk_caller_id }}"/>
        <action application="set" data="effective_caller_id_name=Busibox"/>
        <action application="set" data="hangup_after_bridge=true"/>
        <action application="set" data="ignore_early_media=true"/>
        <action application="bridge" data="sofia/gateway/telnyx/$1"/>
      </condition>
    </extension>
    
    <!-- Park extension for originate -->
    <extension name="park">
      <condition field="destination_number" expression="^park$">
        <action application="park"/>
      </condition>
    </extension>
  </context>
</include>
