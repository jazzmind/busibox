<?xml version="1.0" encoding="utf-8"?>
<!-- FreeSWITCH Variables - Generated by Ansible -->
<include>
  <X-PRE-PROCESS cmd="set" data="sound_prefix=$${base_dir}/sounds/en/us/callie"/>
  
  <!-- SIP settings -->
  <X-PRE-PROCESS cmd="set" data="external_sip_ip=auto-nat"/>
  <X-PRE-PROCESS cmd="set" data="external_rtp_ip=auto-nat"/>
  <X-PRE-PROCESS cmd="set" data="internal_sip_port=5060"/>
  <X-PRE-PROCESS cmd="set" data="external_sip_port=5080"/>
  
  <!-- RTP port range -->
  <X-PRE-PROCESS cmd="set" data="rtp_start_port={{ freeswitch_rtp_start }}"/>
  <X-PRE-PROCESS cmd="set" data="rtp_end_port={{ freeswitch_rtp_end }}"/>
  
  <!-- Codecs -->
  <X-PRE-PROCESS cmd="set" data="global_codec_prefs=PCMU,PCMA"/>
  <X-PRE-PROCESS cmd="set" data="outbound_codec_prefs=PCMU,PCMA"/>
  
  <!-- Domain -->
  <X-PRE-PROCESS cmd="set" data="domain=$${local_ip_v4}"/>
  <X-PRE-PROCESS cmd="set" data="domain_name=$${domain}"/>
  
  <!-- Default password for extensions (change in production) -->
  <X-PRE-PROCESS cmd="set" data="default_password=1234"/>
</include>
