# LiteLLM Environment Configuration
# Auto-generated by Ansible - modifications will be overwritten

# Master Key
LITELLM_MASTER_KEY={{ litellm_master_key }}

# Logging
LITELLM_LOG={{ litellm_log_level | upper }}

{% if litellm_enable_database %}
# Database
DATABASE_URL={{ litellm_database_url }}
LITELLM_DATABASE_URL={{ litellm_database_url }}
{% endif %}

# API keys (from secrets vault)
{% if secrets.openai is defined and secrets.openai.api_key is defined and secrets.openai.api_key %}
OPENAI_API_KEY={{ secrets.openai.api_key }}
{% endif %}
{% if secrets.bedrock is defined and secrets.bedrock.api_key is defined and secrets.bedrock.api_key %}
AWS_BEARER_TOKEN_BEDROCK={{ secrets.bedrock.api_key }}
{% if ':' in secrets.bedrock.api_key %}
AWS_ACCESS_KEY_ID={{ secrets.bedrock.api_key.split(':')[0] }}
AWS_SECRET_ACCESS_KEY={{ secrets.bedrock.api_key.split(':')[1] }}
{% endif %}
{% endif %}
{% if secrets.bedrock is defined and secrets.bedrock.region is defined and secrets.bedrock.region %}
AWS_REGION={{ secrets.bedrock.region }}
{% endif %}

# Disable telemetry
LITELLM_TELEMETRY=False

