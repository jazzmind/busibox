[Unit]
Description=User App - {{ app_id }}
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory={{ app_path }}
ExecStart=/bin/bash -c 'if [ -f .next/standalone/server.js ]; then exec node .next/standalone/server.js; else exec npm start; fi'
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier={{ app_id }}

# Environment
Environment=NODE_ENV=production
Environment=PORT={{ app_port }}
Environment=APP_ID={{ app_id }}
# Cap V8 heap to prevent unbounded memory growth
Environment=NODE_OPTIONS=--max-old-space-size=512
EnvironmentFile=-{{ app_path }}/.env

# Resource limits
{% if cpu_limit is defined %}
CPUQuota={{ (cpu_limit | float * 100) | int }}%
{% endif %}
{% if memory_limit is defined %}
MemoryLimit={{ memory_limit }}
{% endif %}

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths={{ app_path }} {{ app_log_path }}
PrivateTmp=true

[Install]
WantedBy=multi-user.target
