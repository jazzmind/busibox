#!/usr/bin/env bash
# SSL Certificate Expiration Monitoring Script
# Auto-generated by Ansible - modifications will be overwritten
# Purpose: Check certificate expiration and alert if < 7 days (FR-013b)

set -euo pipefail

CERT_PATH="{{ ssl_certificate }}"
ALERT_DAYS=7

# Check if certificate exists
if [[ ! -f "${CERT_PATH}" ]]; then
    echo "ERROR: Certificate not found: ${CERT_PATH}"
    exit 1
fi

# Get expiration date
EXPIRY_DATE=$(openssl x509 -in "${CERT_PATH}" -noout -enddate | cut -d= -f2)
EXPIRY_EPOCH=$(date -d "${EXPIRY_DATE}" +%s)
CURRENT_EPOCH=$(date +%s)
DAYS_UNTIL_EXPIRY=$(( (EXPIRY_EPOCH - CURRENT_EPOCH) / 86400 ))

echo "Certificate: ${CERT_PATH}"
echo "Expires: ${EXPIRY_DATE}"
echo "Days until expiry: ${DAYS_UNTIL_EXPIRY}"

if [[ ${DAYS_UNTIL_EXPIRY} -lt 0 ]]; then
    echo "❌ CRITICAL: Certificate has EXPIRED!"
    exit 2
elif [[ ${DAYS_UNTIL_EXPIRY} -lt ${ALERT_DAYS} ]]; then
    echo "⚠️  WARNING: Certificate expires in ${DAYS_UNTIL_EXPIRY} days!"
    # TODO: Send alert to operators (T082)
    exit 1
else
    echo "✓ Certificate is valid"
    exit 0
fi

