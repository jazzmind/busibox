# HTTP to HTTPS Redirect
# Auto-generated by Ansible - modifications will be overwritten
# Purpose: Redirect all HTTP traffic to HTTPS (FR-016)

server {
    listen 80;
    listen [::]:80;
    
    server_name {{ domain }} *.{{ domain }};
    
    # Let's Encrypt ACME challenge (allow HTTP for certificate validation)
    location ^~ /.well-known/acme-challenge/ {
        default_type "text/plain";
        root /var/www/html;
    }
    
    # Redirect all other HTTP requests to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

