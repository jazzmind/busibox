---
# Ansible Vault - Encrypted Deployment Configuration
# Created: 2025-10-15
# Updated: 2026-01-29
# Purpose: Bootstrap/infrastructure secrets + environment config
#
# IMPORTANT: This file should be encrypted with ansible-vault
#   To encrypt: ansible-vault encrypt provision/ansible/roles/secrets/vars/vault.yml
#   To edit: ansible-vault edit provision/ansible/roles/secrets/vars/vault.yml
#   To decrypt: ansible-vault decrypt provision/ansible/roles/secrets/vars/vault.yml
#
# ⚠️  IMPORTANT: This file is deployment-specific and should NOT be version controlled
#     Each deployment (customer/environment) has their own vault.yml
#     This repo is generic and reusable across multiple deployments
#
# ============================================================================
# VAULT ARCHITECTURE (Simplified - 2026-01)
# ============================================================================
#
# This vault contains ONLY BASE SECRETS. Per-service secrets are now computed
# at deploy time from these base values using Ansible templates.
#
# Benefits:
#   - Single source of truth for each secret
#   - No duplication between base and per-service sections
#   - Templates compute database_url, jwt_secret, etc. from base values
#   - Easier to update secrets (change in one place)
#
# PRODUCTION VAULT SYNC INSTRUCTIONS:
# ============================================================================
#
# After updating vault.example.yml, sync production vault:
#
# 1. BACKUP production vault:
#    cp provision/ansible/roles/secrets/vars/vault.yml vault.yml.backup
#
# 2. DECRYPT production vault:
#    ansible-vault decrypt provision/ansible/roles/secrets/vars/vault.yml
#
# 3. REVIEW and UPDATE:
#    - Add any new base secrets (e.g., litellm_master_key)
#    - Remove deprecated sections (per-service secrets like secrets['ai-portal'])
#    - Keep all actual secret VALUES from production
#
# 4. RE-ENCRYPT:
#    ansible-vault encrypt provision/ansible/roles/secrets/vars/vault.yml
#
# 5. TEST on staging first:
#    make install SERVICE=authz INV=inventory/staging
#    make install SERVICE=ai-portal INV=inventory/staging
#
# 6. Deploy to production after verifying staging works.
#
# ============================================================================
# SECRET STORAGE ARCHITECTURE
# ============================================================================
#
# WHAT GOES IN THIS VAULT (bootstrap/infrastructure secrets):
#   - Network configuration (octets, domain)
#   - Database password (can't store DB password in DB!)
#   - MinIO credentials (needed before object storage available)
#   - JWT/auth secrets (needed at service startup)
#   - SSH keys (Ansible connectivity)
#   - SSL certificates
#   - GitHub personal access token (for private repos during install)
#
# WHAT GOES IN DATABASE CONFIG API (runtime, changeable):
#   - SMTP credentials (changeable after install)
#   - External API keys (OpenAI, HuggingFace, Resend, Bedrock)
#   - OAuth provider credentials (Microsoft Entra, GitHub OAuth)
#   - Email settings (allowed domains, admin email)
#   - Feature flags
#
# The database config API is accessible at: GET/PUT /api/v1/config/{key}
# See: docs/reference/config-api.md for details
#
# ============================================================================

# ============================================================================
# SECTION 1: INFRASTRUCTURE (Required at container creation)
# ============================================================================

# Production Network Base
network_base_octets_production: "10.96.200"

# Staging Network Base (typically production + 1 in 3rd octet)
network_base_octets_staging: "10.96.201"

# Base domain for this deployment
base_domain: "maigentpartners.com"

# SSL Configuration
ssl_email: "admin@maigentpartners.com"

# ============================================================================
# SECTION 2: BOOTSTRAP SECRETS (Required before services can start)
# ============================================================================
secrets:


  # ---------------------------------------------------------------------------
  # 2.1 GitHub Personal Access Token (needed for private repo access)
  # ---------------------------------------------------------------------------
  github:
    # GitHub Access Token (for private repository deployments)
    # Create at: https://github.com/settings/tokens
    # Scope: repo (full control of private repositories)
    personal_access_token: "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"

    # NOTE: GitHub OAuth is now RUNTIME CONFIG stored in database
    # Configure via AI Portal admin settings after installation
    client_id: "CHANGE_ME_GITHUB_OAUTH_CLIENT_ID"
    client_secret: "CHANGE_ME_GITHUB_OAUTH_CLIENT_SECRET"

  # ---------------------------------------------------------------------------
  # 2.2 Database Credentials (MUST be in vault - can't store in DB!)
  # ---------------------------------------------------------------------------
  postgresql:
    password: "5eAi9s6n4Lu4JAcyrK8aRN3osFD42oP"
  
  # ---------------------------------------------------------------------------
  # 2.3 Object Storage Credentials (needed before MinIO starts)
  # ---------------------------------------------------------------------------
  minio:
    root_user: "minioadmin"  # MinIO root username
    root_password: "IldChn6jAaxSDmC8x7hqCAO00qHpmlU"  # MinIO root password

  # ---------------------------------------------------------------------------
  # 2.4 Auth/Security Secrets (needed at service startup)
  # ---------------------------------------------------------------------------
  # Generate all these with: openssl rand -hex 32
  jwt_secret: "6688a6aaf7032c27c6e4743da147ec94b9a5fee718eca98caf4f876ec28bb058"
  session_secret: "CHANGE_ME_SESSION_SECRET_32_BYTES"
  authz_master_key: "b6YaOyOXBY0+D5crpXvvYbCdPBkYviGmXVdQeKcbvQs="
  litellm_api_key: "sk-d17e447cbbfd9f3fb6474dd85d723b8b"
  litellm_master_key: "sk-CHANGE_ME_LITELLM_MASTER_KEY"  # LiteLLM internal master key
  encryption_key: "CHANGE_ME_ENCRYPTION_KEY_FOR_SECRETS_STORAGE_32_BYTES"

  # ---------------------------------------------------------------------------
  # 2.5 Admin Bootstrap (first admin user)
  # ---------------------------------------------------------------------------
  # Comma-separated list of admin emails (bootstrapped by authz on startup)
  admin_emails: "wes@sonnenreich.com"
  
  # Comma-separated list of allowed email domains for authentication
  allowed_email_domains: "*"

  # ---------------------------------------------------------------------------
  # 2.6 SSH/SSL Infrastructure
  # ---------------------------------------------------------------------------
  # Container SSH key for remote deployments (optional)
  container_ssh_private_key: ""

  # Let's Encrypt / SSL
  letsencrypt:
    email: "admin@maigentpartners.com"

  # Tailscale VPN Configuration (optional)
  tailscale:
    auth_key: "CHANGE_ME_TAILSCALE_AUTH_KEY"

# ============================================================================
# SECTION 3: RUNTIME CONFIG (Can be moved to database after install)
# ============================================================================
# These are included here for backward compatibility but should ideally
# be managed via the deploy-api config endpoints after installation.
# See: GET/PUT /api/v1/config/{key}

  # ---------------------------------------------------------------------------
  # 3.1 Email/SMTP (runtime - changeable via admin UI)
  # ---------------------------------------------------------------------------
  smtp:
    host: "smtp.office365.com"
    port: "587"
    user: "ainotifications@jaycashman.com"
    password: "Z!441005855807aw"
    from_email: "CashmanAI <ainotifications@jaycashman.com>"
    secure: "false"
  
  resend_api_key: ""

  # ---------------------------------------------------------------------------
  # 3.2 External AI Providers (runtime - changeable via admin UI)
  # ---------------------------------------------------------------------------
  huggingface:
    token: "CHANGE_ME_HF_TOKEN"
  
  openai:
    api_key: "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"

  bedrock:
    api_key: "ABSKYmVkcm9jay1hdC01MDUyODU3NTcxOTY6ZGlrT0hIYnU0N3hCTnlQbUJqbEwreWVsTlNiZkE4RjhBSlFGV1BxaEtodnFkT0pLaHVhQU5lUnA0Mlk9"
    region: "us-east-1"

  # ---------------------------------------------------------------------------
  # 3.3 OAuth Providers (runtime - configure in AI Portal admin)
  # ---------------------------------------------------------------------------
  microsoft:
    client_id: "CHANGE_ME_MICROSOFT_CLIENT_ID"
    client_secret: "CHANGE_ME_MICROSOFT_CLIENT_SECRET"
    tenant_id: "common"

  # ---------------------------------------------------------------------------
  # 3.4 Bridge Service (optional - Zero Trust authentication)
  # ---------------------------------------------------------------------------
  bridge:
    phone_number: "CHANGE_ME_BRIDGE_SIGNAL_PHONE_NUMBER"
    # Delegation token for the signal-bot service account (Zero Trust)
    # Create via POST /oauth/delegation/create with an admin session token
    # This is a long-lived token (default 3 years) that the bridge service
    # exchanges for short-lived agent-api tokens at runtime.
    delegation_token: ""

  # ---------------------------------------------------------------------------
  # 3.5 SSL Certificates (for ssl_mode: provisioned, optional)
  # ---------------------------------------------------------------------------
  ssl_certificates:
    certificate: |
      -----BEGIN CERTIFICATE-----
      CHANGE_ME_YOUR_SSL_CERTIFICATE_HERE
      -----END CERTIFICATE-----
    private_key: |
      -----BEGIN PRIVATE KEY-----
      CHANGE_ME_YOUR_PRIVATE_KEY_HERE
      -----END PRIVATE KEY-----
    chain: ""

# ============================================================================
# NOTE: Per-service secrets (secrets['ai-portal'], secrets['agent-server'], etc.)
# are NO LONGER stored in the vault. They are now computed at deploy time from
# the base secrets above, using Ansible templates.
#
# This simplifies secret management:
# - Only base secrets need to be configured here
# - Service-specific values are derived in templates (app.env.j2, etc.)
# - Reduces duplication and potential for drift
#
# See: provision/ansible/roles/secrets/templates/app.env.j2
# See: provision/ansible/roles/agent_api/templates/agent-api.env.j2
# ============================================================================
