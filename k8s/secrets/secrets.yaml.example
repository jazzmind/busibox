# Busibox Kubernetes Secrets
# ===========================
# Copy this file to secrets.yaml and fill in your actual values.
# DO NOT commit secrets.yaml to git!
#
# To create the secret in your cluster:
#   kubectl apply -f k8s/secrets/secrets.yaml -n busibox
#
# Or use the deploy script which generates this from vault:
#   make k8s-deploy ENV=rackspace-spot
#
apiVersion: v1
kind: Secret
metadata:
  name: busibox-secrets
  namespace: busibox
  labels:
    app.kubernetes.io/part-of: busibox
type: Opaque
stringData:
  # PostgreSQL
  POSTGRES_PASSWORD: "CHANGE_ME"

  # MinIO
  MINIO_ACCESS_KEY: "minioadmin"
  MINIO_SECRET_KEY: "CHANGE_ME"

  # Neo4j
  NEO4J_AUTH: "neo4j/CHANGE_ME"

  # AuthZ
  AUTHZ_MASTER_KEY: "CHANGE_ME"

  # LiteLLM
  LITELLM_API_KEY: "CHANGE_ME"
  LITELLM_MASTER_KEY: "CHANGE_ME"

  # Admin
  ADMIN_EMAILS: "your-email@example.com"

  # LLM API Keys (optional - set if using cloud providers)
  OPENAI_API_KEY: ""
  ANTHROPIC_API_KEY: ""

  # AWS Bedrock (optional - bearer token or access_key:secret_key format)
  BEDROCK_API_KEY: ""
  AWS_REGION_NAME: "us-east-1"

  # GitHub (for pulling private images)
  GITHUB_TOKEN: ""

  # Rackspace Spot API token (for GPU burst provisioning)
  RACKSPACE_SPOT_TOKEN: ""
